diff --git a/.config/nvim/lua/etch.lua b/.config/nvim/lua/etch.lua
new file mode 100644
--- /dev/null
+++ b/.config/nvim/lua/etch.lua
@@ -0,0 +1,494 @@
+-- etch.lua — Persistent Local Code Review Annotations
+-- See ETCH.md for full specification
+
+local M = {}
+
+-- In-memory state
+local state = {
+  annotations = {},  -- { [abs_path] = { [line_number] = annotation } }
+  ns = vim.api.nvim_create_namespace("etch"),
+  git_roots = {},    -- per-directory cache
+  dirty = false,
+  loaded = false,
+}
+
+---------------------------------------------------------------------------
+-- Git helpers
+---------------------------------------------------------------------------
+
+local function get_git_root(path)
+  if not path or path == "" then path = vim.fn.getcwd() end
+  local dir = vim.fn.isdirectory(path) == 1 and path or vim.fn.fnamemodify(path, ":h")
+  if state.git_roots[dir] then return state.git_roots[dir] end
+
+  local root = vim.fn.systemlist("git -C " .. vim.fn.shellescape(dir) .. " rev-parse --show-toplevel")[1]
+  if vim.v.shell_error == 0 and root then
+    state.git_roots[dir] = root
+    return root
+  end
+  return nil
+end
+
+local function get_rel_path(abs_path)
+  local root = get_git_root(abs_path)
+  if root and abs_path:sub(1, #root) == root then
+    return abs_path:sub(#root + 2)
+  end
+  return abs_path
+end
+
+local function get_abs_path(rel_path, root)
+  if root then
+    return root .. "/" .. rel_path
+  end
+  return rel_path
+end
+
+---------------------------------------------------------------------------
+-- Persistence
+---------------------------------------------------------------------------
+
+local function get_etch_path(path)
+  local root = get_git_root(path or vim.api.nvim_buf_get_name(0))
+  if not root then return nil end
+  return root .. "/.etch.json"
+end
+
+local function load_annotations(path)
+  local etch_path = get_etch_path(path)
+  if not etch_path then return end
+
+  local fp = io.open(etch_path, "r")
+  if not fp then return end
+
+  local content = fp:read("*a")
+  fp:close()
+
+  local ok, data = pcall(vim.fn.json_decode, content)
+  if not ok or not data or not data.annotations then return end
+
+  local root = get_git_root(path)
+  state.annotations = {}
+  for rel_path, file_annotations in pairs(data.annotations) do
+    local abs = get_abs_path(rel_path, root)
+    state.annotations[abs] = {}
+    for _, ann in ipairs(file_annotations) do
+      state.annotations[abs][ann.line] = ann
+    end
+  end
+  state.loaded = true
+end
+
+local function save_annotations(path)
+  local etch_path = get_etch_path(path)
+  if not etch_path then return end
+
+  local root = get_git_root(path)
+  local data = { version = 1, annotations = {} }
+
+  for abs, file_anns in pairs(state.annotations) do
+    local file_root = get_git_root(abs)
+    if file_root == root then
+      local rel = get_rel_path(abs)
+      local ann_list = {}
+      for _, ann in pairs(file_anns) do
+        table.insert(ann_list, ann)
+      end
+      table.sort(ann_list, function(a, b) return a.line < b.line end)
+      if #ann_list > 0 then
+        data.annotations[rel] = ann_list
+      end
+    end
+  end
+
+  local fp = io.open(etch_path, "w")
+  if not fp then
+    vim.notify("Etch: Failed to save to " .. etch_path, vim.log.levels.ERROR)
+    return
+  end
+  fp:write(vim.fn.json_encode(data))
+  fp:close()
+  state.dirty = false
+end
+
+local save_timer = nil
+local function save_debounced(path)
+  state.dirty = true
+  if save_timer then
+    save_timer:stop()
+  end
+  save_timer = vim.defer_fn(function()
+    if state.dirty then
+      save_annotations(path)
+    end
+  end, 2000)
+end
+
+---------------------------------------------------------------------------
+-- Rendering
+---------------------------------------------------------------------------
+
+local function render_file(bufnr)
+  local abs_path = vim.api.nvim_buf_get_name(bufnr)
+  local file_anns = state.annotations[abs_path]
+
+  vim.api.nvim_buf_clear_namespace(bufnr, state.ns, 0, -1)
+
+  if not file_anns then return end
+
+  local line_count = vim.api.nvim_buf_line_count(bufnr)
+  for line, ann in pairs(file_anns) do
+    local row = line - 1
+    if row >= 0 and row < line_count then
+      local virt_text
+      if ann.orphaned then
+        virt_text = {
+          { "  ── [?] ", "EtchOrphaned" },
+          { ann.text, "Comment" },
+        }
+      else
+        virt_text = {
+          { "  ── ", "EtchSeparator" },
+          { ann.text, "EtchAnnotation" },
+        }
+      end
+      vim.api.nvim_buf_set_extmark(bufnr, state.ns, row, 0, {
+        virt_text = virt_text,
+        virt_text_pos = "eol",
+        hl_mode = "combine",
+      })
+    end
+  end
+end
+
+local function render_current()
+  render_file(vim.api.nvim_get_current_buf())
+end
+
+---------------------------------------------------------------------------
+-- Re-anchoring
+---------------------------------------------------------------------------
+
+local function reanchor_file(bufnr)
+  local abs_path = vim.api.nvim_buf_get_name(bufnr)
+  local file_anns = state.annotations[abs_path]
+  if not file_anns then return end
+
+  local lines = vim.api.nvim_buf_get_lines(bufnr, 0, -1, false)
+  local updated = {}
+  local changed = false
+
+  for old_line, ann in pairs(file_anns) do
+    local target_content = ann.anchor and ann.anchor.content
+    if not target_content then
+      updated[old_line] = ann
+    else
+      local current = lines[old_line] and vim.trim(lines[old_line]) or ""
+      if current == target_content then
+        if ann.orphaned then
+          ann.orphaned = nil
+          changed = true
+        end
+        updated[old_line] = ann
+      else
+        local found = false
+        local max_search = 50
+        for offset = 1, max_search do
+          local above = old_line - offset
+          if above >= 1 and vim.trim(lines[above] or "") == target_content then
+            ann.line = above
+            ann.orphaned = nil
+            updated[above] = ann
+            found = true
+            changed = true
+            break
+          end
+          local below = old_line + offset
+          if below <= #lines and vim.trim(lines[below] or "") == target_content then
+            ann.line = below
+            ann.orphaned = nil
+            updated[below] = ann
+            found = true
+            changed = true
+            break
+          end
+        end
+
+        if not found then
+          ann.orphaned = true
+          updated[old_line] = ann
+          changed = true
+        end
+      end
+    end
+  end
+
+  if changed then
+    state.annotations[abs_path] = updated
+    save_debounced(abs_path)
+  end
+end
+
+---------------------------------------------------------------------------
+-- Add / Edit / Delete
+---------------------------------------------------------------------------
+
+local function add_annotation(line, bufnr)
+  bufnr = bufnr or vim.api.nvim_get_current_buf()
+  line = line or vim.fn.line(".")
+  local abs_path = vim.api.nvim_buf_get_name(bufnr)
+
+  if abs_path == "" then
+    vim.notify("Etch: Buffer has no file", vim.log.levels.WARN)
+    return
+  end
+
+  local existing = state.annotations[abs_path] and state.annotations[abs_path][line]
+  local default_text = existing and existing.text or ""
+
+  vim.ui.input({
+    prompt = "Etch: ",
+    default = default_text,
+  }, function(input)
+    if not input or input == "" then return end
+
+    local line_content = vim.api.nvim_buf_get_lines(bufnr, line - 1, line, false)[1] or ""
+    local hash = vim.fn.systemlist("git rev-parse --short HEAD")[1] or "unknown"
+
+    if not state.annotations[abs_path] then
+      state.annotations[abs_path] = {}
+    end
+
+    state.annotations[abs_path][line] = {
+      line = line,
+      text = input,
+      created = os.date("!%Y-%m-%dT%H:%M:%S"),
+      anchor = {
+        content = vim.trim(line_content),
+        hash = hash,
+      },
+    }
+
+    render_current()
+    save_debounced(abs_path)
+    vim.notify("Etch: Annotation added", vim.log.levels.INFO)
+  end)
+end
+
+local function delete_annotation(line, bufnr)
+  bufnr = bufnr or vim.api.nvim_get_current_buf()
+  line = line or vim.fn.line(".")
+  local abs_path = vim.api.nvim_buf_get_name(bufnr)
+
+  if state.annotations[abs_path] and state.annotations[abs_path][line] then
+    state.annotations[abs_path][line] = nil
+    if next(state.annotations[abs_path]) == nil then
+      state.annotations[abs_path] = nil
+    end
+    render_current()
+    save_debounced(abs_path)
+    vim.notify("Etch: Annotation removed", vim.log.levels.INFO)
+  else
+    vim.notify("Etch: No annotation on this line", vim.log.levels.WARN)
+  end
+end
+
+local function delete_file_annotations(bufnr)
+  bufnr = bufnr or vim.api.nvim_get_current_buf()
+  local abs_path = vim.api.nvim_buf_get_name(bufnr)
+
+  if not state.annotations[abs_path] then
+    vim.notify("Etch: No annotations in this file", vim.log.levels.WARN)
+    return
+  end
+
+  local count = 0
+  for _ in pairs(state.annotations[abs_path]) do count = count + 1 end
+
+  vim.ui.input({
+    prompt = string.format("Delete all %d annotations in this file? (y/N): ", count),
+  }, function(input)
+    if input and input:lower() == "y" then
+      state.annotations[abs_path] = nil
+      render_current()
+      save_debounced(abs_path)
+      vim.notify("Etch: Removed " .. count .. " annotations", vim.log.levels.INFO)
+    end
+  end)
+end
+
+---------------------------------------------------------------------------
+-- Browse (Snacks Picker)
+---------------------------------------------------------------------------
+
+local function browse_annotations()
+  load_annotations(vim.api.nvim_buf_get_name(0))
+
+  local items = {}
+
+  for abs_path, file_anns in pairs(state.annotations) do
+    local rel_path = get_rel_path(abs_path)
+    for line, ann in pairs(file_anns) do
+      table.insert(items, {
+        text = string.format("%s:%d  ──  %s", rel_path, line, ann.text),
+        file = abs_path,
+        pos = { line, 0 },
+        annotation = ann,
+        rel_path = rel_path,
+        ann_line = line,
+      })
+    end
+  end
+
+  table.sort(items, function(a, b) return a.text < b.text end)
+
+  if #items == 0 then
+    vim.notify("Etch: No annotations found", vim.log.levels.INFO)
+    return
+  end
+
+  Snacks.picker({
+    source = "etch",
+    title = "Etch — Annotations",
+    items = items,
+    format = function(item, picker)
+      local ret = {} ---@type snacks.picker.Highlight[]
+      ret[#ret + 1] = { item.rel_path .. ":" .. item.ann_line, "SnacksPickerFile" }
+      ret[#ret + 1] = { "  ── ", "EtchSeparator" }
+      ret[#ret + 1] = { item.annotation.text, "EtchAnnotation" }
+      return ret
+    end,
+    preview = "file",
+    confirm = function(picker, item)
+      picker:close()
+      if item then
+        vim.cmd("edit " .. vim.fn.fnameescape(item.file))
+        vim.api.nvim_win_set_cursor(0, { item.ann_line, 0 })
+        vim.cmd("normal! zz")
+      end
+    end,
+    actions = {
+      etch_delete = function(picker, item)
+        if not item then return end
+        if state.annotations[item.file] then
+          state.annotations[item.file][item.ann_line] = nil
+          if next(state.annotations[item.file]) == nil then
+            state.annotations[item.file] = nil
+          end
+        end
+        save_debounced(item.file)
+        for _, buf in ipairs(vim.api.nvim_list_bufs()) do
+          if vim.api.nvim_buf_get_name(buf) == item.file then
+            render_file(buf)
+          end
+        end
+        vim.notify("Etch: Deleted annotation", vim.log.levels.INFO)
+        picker:close()
+        vim.defer_fn(browse_annotations, 100)
+      end,
+    },
+    win = {
+      input = {
+        keys = {
+          ["<C-d>"] = { "etch_delete", mode = { "n", "i" } },
+        },
+      },
+    },
+  })
+end
+
+---------------------------------------------------------------------------
+-- Autocmds
+---------------------------------------------------------------------------
+
+local function setup_autocmds()
+  local group = vim.api.nvim_create_augroup("etch", { clear = true })
+
+  vim.api.nvim_create_autocmd("BufRead", {
+    group = group,
+    callback = function(ev)
+      if not get_git_root(vim.api.nvim_buf_get_name(ev.buf)) then return end
+      if not state.loaded then
+        load_annotations(vim.api.nvim_buf_get_name(ev.buf))
+      end
+      reanchor_file(ev.buf)
+      render_file(ev.buf)
+    end,
+  })
+
+  vim.api.nvim_create_autocmd("BufWritePost", {
+    group = group,
+    callback = function(ev)
+      reanchor_file(ev.buf)
+      render_file(ev.buf)
+    end,
+  })
+
+  vim.api.nvim_create_autocmd("VimLeavePre", {
+    group = group,
+    callback = function()
+      if state.dirty then
+        save_annotations(vim.api.nvim_buf_get_name(0))
+      end
+    end,
+  })
+
+  vim.api.nvim_create_autocmd("BufEnter", {
+    group = group,
+    callback = function(ev)
+      render_file(ev.buf)
+    end,
+  })
+end
+
+---------------------------------------------------------------------------
+-- Public API
+---------------------------------------------------------------------------
+
+function M.setup(opts)
+  opts = opts or {}
+
+  vim.api.nvim_set_hl(0, "EtchAnnotation", { link = "DiagnosticHint", default = true })
+  vim.api.nvim_set_hl(0, "EtchSeparator", { link = "Comment", default = true })
+  vim.api.nvim_set_hl(0, "EtchOrphaned", { link = "DiagnosticWarn", default = true })
+
+  load_annotations(vim.api.nvim_buf_get_name(0))
+  setup_autocmds()
+
+  for _, buf in ipairs(vim.api.nvim_list_bufs()) do
+    if vim.api.nvim_buf_is_loaded(buf) and vim.api.nvim_buf_get_name(buf) ~= "" then
+      render_file(buf)
+    end
+  end
+end
+
+function M.add(line, bufnr)
+  add_annotation(line, bufnr)
+end
+
+function M.delete(line, bufnr)
+  delete_annotation(line, bufnr)
+end
+
+function M.delete_file(bufnr)
+  delete_file_annotations(bufnr)
+end
+
+function M.browse()
+  browse_annotations()
+end
+
+function M.reload()
+  state.annotations = {}
+  state.git_roots = {}
+  state.loaded = false
+  load_annotations(vim.api.nvim_buf_get_name(0))
+  for _, buf in ipairs(vim.api.nvim_list_bufs()) do
+    if vim.api.nvim_buf_is_loaded(buf) then
+      render_file(buf)
+    end
+  end
+  vim.notify("Etch: Reloaded", vim.log.levels.INFO)
+end
+
+return M
