diff --git a/.config/nvim/lua/deja-vu.lua b/.config/nvim/lua/deja-vu.lua
new file mode 100644
--- /dev/null
+++ b/.config/nvim/lua/deja-vu.lua
@@ -0,0 +1,175 @@
+local M = {}
+
+local function parse_git_log_L(raw)
+  local entries = {}
+  local chunks = vim.split(raw, "\ncommit ", { plain = true })
+
+  for i, chunk in ipairs(chunks) do
+    if i == 1 then
+      chunk = chunk:gsub("^commit ", "")
+    end
+
+    local hash = chunk:match("^(%x+)")
+    local date = chunk:match("Date:%s+(.-)%s*\n")
+    local message = chunk:match("\n\n%s+(.-)%s*\n")
+
+    local plus_lines = {}
+    for line in chunk:gmatch("\n%+([^\n]*)") do
+      if not line:match("^%+%+ ") then
+        table.insert(plus_lines, line)
+      end
+    end
+
+    local content = table.concat(plus_lines, "\n")
+    if content == "" then
+      local ctx = {}
+      for line in chunk:gmatch("\n ([^\n]+)") do
+        table.insert(ctx, line)
+      end
+      content = table.concat(ctx, "\n")
+    end
+
+    if hash then
+      table.insert(entries, {
+        hash = hash,
+        short_hash = hash:sub(1, 7),
+        date = date or "unknown",
+        message = message or "",
+        line_content = content,
+      })
+    end
+  end
+
+  return entries
+end
+
+local function open_picker(entries, rel_path, git_root)
+  local items = {}
+  for _, entry in ipairs(entries) do
+    local msg = entry.message:sub(1, 40)
+    local line_preview = entry.line_content:gsub("\n", " "):sub(1, 60)
+
+    table.insert(items, {
+      text = string.format("%s %s %s %s",
+        entry.short_hash, entry.date, msg, line_preview),
+      _hash_display = entry.short_hash .. "  ",
+      _date_display = entry.date .. "  ",
+      _msg_display = msg .. "  │  ",
+      _preview_display = line_preview,
+      hash = entry.hash,
+      short_hash = entry.short_hash,
+      file = rel_path,
+    })
+  end
+
+  require("snacks").picker({
+    title = "Déjà Vu — Line History",
+    items = items,
+    format = function(item)
+      return {
+        { item._hash_display, "Comment" },
+        { item._date_display, "Number" },
+        { item._msg_display, "String" },
+        { item._preview_display, "Normal" },
+      }
+    end,
+    confirm = function(picker, item)
+      picker:close()
+      if item and item.hash then
+        vim.cmd("DiffviewOpen " .. item.hash .. "^.." .. item.hash .. " -- " .. item.file)
+      end
+    end,
+    actions = {
+      yank_hash = function(_, item)
+        if item then
+          vim.fn.setreg('"', item.hash)
+          vim.notify("Yanked: " .. item.hash)
+        end
+      end,
+      open_file_at_commit = function(picker, item)
+        picker:close()
+        if item then
+          vim.cmd("vnew")
+          local result = vim.system(
+            { "git", "show", item.hash .. ":" .. item.file },
+            { cwd = git_root, text = true }
+          ):wait()
+          if result.code == 0 and result.stdout then
+            local lines = vim.split(result.stdout, "\n", { plain = true })
+            vim.api.nvim_buf_set_lines(0, 0, -1, false, lines)
+          else
+            vim.api.nvim_buf_set_lines(0, 0, -1, false,
+              { "-- Failed to load file at " .. item.short_hash })
+          end
+          vim.bo.buftype = "nofile"
+          vim.bo.bufhidden = "wipe"
+          vim.bo.modifiable = false
+          local ext = vim.fn.fnamemodify(item.file, ":e")
+          if ext ~= "" then
+            vim.bo.filetype = ext
+          end
+          vim.api.nvim_buf_set_name(0, item.file .. "@" .. item.short_hash)
+        end
+      end,
+    },
+    win = {
+      input = {
+        keys = {
+          ["<C-y>"] = { "yank_hash", mode = { "n", "i" } },
+          ["<C-o>"] = { "open_file_at_commit", mode = { "n", "i" } },
+        },
+      },
+    },
+  })
+end
+
+function M.show(line_start, line_end)
+  local file = vim.api.nvim_buf_get_name(0)
+  if file == "" then
+    vim.notify("Déjà Vu: Buffer has no file", vim.log.levels.WARN)
+    return
+  end
+
+  local git_root = vim.fn.systemlist("git rev-parse --show-toplevel")[1]
+  if vim.v.shell_error ~= 0 then
+    vim.notify("Déjà Vu: Not in a git repo", vim.log.levels.WARN)
+    return
+  end
+
+  local rel_path = file:sub(#git_root + 2)
+
+  local check = vim.system(
+    { "git", "log", "--oneline", "-1", "--", rel_path },
+    { cwd = git_root, text = true }
+  ):wait()
+  if check.code ~= 0 or (check.stdout and check.stdout:match("^%s*$")) then
+    vim.notify("Déjà Vu: File has no git history", vim.log.levels.WARN)
+    return
+  end
+
+  line_start = line_start or vim.fn.line(".")
+  line_end = line_end or line_start
+
+  local result = vim.system({
+    "git", "log",
+    "-L", string.format("%d,%d:%s", line_start, line_end, rel_path),
+    "--format=commit %H%nDate: %ad%n%n    %s",
+    "--date=short",
+    "-n", "100",
+  }, { cwd = git_root, text = true }):wait()
+
+  if result.code ~= 0 then
+    vim.notify("Déjà Vu: git log -L failed:\n" .. (result.stderr or ""), vim.log.levels.ERROR)
+    return
+  end
+
+  local entries = parse_git_log_L(result.stdout or "")
+  if #entries == 0 then
+    vim.notify("Déjà Vu: No history found for this line", vim.log.levels.INFO)
+    return
+  end
+
+  open_picker(entries, rel_path, git_root)
+end
+
+return M
diff --git a/.config/nvim/lua/keymaps.lua b/.config/nvim/lua/keymaps.lua
--- a/.config/nvim/lua/keymaps.lua
+++ b/.config/nvim/lua/keymaps.lua
@@ -280,3 +280,15 @@
     vim.notify("Sent to new Cascade chat (" .. #text .. " chars)", vim.log.levels.INFO)
   end
 end, { desc = 'Send buffer to new Cascade chat' })
+
+-- Déjà Vu: Line-level git time machine
+vim.keymap.set('n', '<leader>hh', function()
+  require('deja-vu').show()
+end, { desc = 'Déjà Vu: Line history' })
+
+vim.keymap.set('v', '<leader>hH', function()
+  local start = vim.fn.line("v")
+  local finish = vim.fn.line(".")
+  if start > finish then start, finish = finish, start end
+  require('deja-vu').show(start, finish)
+end, { desc = 'Déjà Vu: Range history' })
